// Assembler's Output
    // The assembler translates the assembly code into binary data,
    // and saves them in this file.

1100001000000101    // ADDI R1, R0, 5 => R1 = 0x0005
1011010000000011    // LUI R2, 3 => R2 = 3 << 10 = 0x0C00
0000011001010000    // ADD R3, R1, R2 => R3 = 0x0C05
1010001010000010    // BNE R1, R2, 2 => Taken
1100011000000001    // ADDI R3, R0, 1 => R3 = 0x0001
1100011000000010    // ADDI R3, R0, 2 => R3 = 0x0002
1110001010000000    // SW R1, 0(R2) => ram[0x00] = 0x0005
1101011010000000    // LW R3, 0(R2) => R3 = ram[0x00] = 0x0005
1011010000111111    // LUI R2, 63 => R2 = 63 << 10 = 0xFC00
1110001010000000    // SW R1, 0(R2) => outport = 0x0005
1101011010000010    // LW R3, 2(R2) => R3 = inport (0x0009 in current tb)
0101011001001000    // LSL R3, R1, R1 => R3 = 5 << 5 = 0x00A0
0110011001001000    // LSR R3, R1, R1 => R3 = 5 >> 5 = 0x0000
1000011001000000    // CLZ R3, R1 => R3 = 0x000D
0111011001001000    // MAC R3, R1, R1 => R3 = R3 + 0x0019 = 0x0026
1111000000000000    // HALT